# API Keys for Multi-Modal Evidence Review
# Copy this file to .env and fill in your keys.
# At least ONE key is needed for the system to run.

# NVIDIA (Primary - Recommended, free unlimited credits)
# Get key at: https://build.nvidia.com/
NVIDIA_API_KEY=your_nvidia_api_key_here

# OpenRouter (Fallback 1 - free tier ~20 RPM)
# Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Gemini (Fallback 2 - supports multiple keys for rotation)
# Get key at: https://aistudio.google.com/apikey
# Multiple keys separated by commas:
GEMINI_API_KEYS=key1,key2,key3,key4,key5,key6

# Groq (Fallback 3 - last resort due to TPD limits)
# Get key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
